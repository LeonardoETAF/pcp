  "query": "INSERT INTO pcp.filtro_salvo (usuario_id, nome, filtro)\n           VALUES ($1, $2, $3)\n           ON CONFLICT (usuario_id, nome)\n             DO UPDATE SET filtro = EXCLUDED.filtro, criado_em = now()\n           RETURNING id, nome, filtro",
