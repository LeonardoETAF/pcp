{
  "db_name": "PostgreSQL",
  "query": "SELECT codigo_estoque                  AS \"codigo_estoque!\",\n                  EXTRACT(MONTH FROM dt_ref)::int4 AS \"mes!\",\n                  SUM(qtd_vendida)::float8        AS \"total!\",\n                  COUNT(DISTINCT dt_ref)          AS \"dias!\"\n           FROM pcp.vendas_dia\n           WHERE dt_ref >= $1 AND dt_ref < $2 AND qtd_vendida > 0\n           GROUP BY 1, 2\n           ORDER BY 1, 2",
