# Modelo de variáveis de ambiente. Copie para `.env` e ajuste os valores.
# NUNCA versione o `.env` — ele guarda secrets (CLAUDE.md §7.4). Só este exemplo vai pro git.

# Conexão do Postgres dedicado (usada por SQLx e pelo app).
DATABASE_URL=postgres://pcp:CHANGE_ME@localhost:5433/pcp

# Usadas pelo docker-compose.yml ao subir o banco local.
POSTGRES_PASSWORD=CHANGE_ME
PCP_DB_PORT=5433

# Autenticação (CLAUDE.md §7). Segredo do JWT: use algo aleatório com 32+ caracteres.
PCP_JWT_SECRET=CHANGE_ME_use_um_segredo_aleatorio_com_32_ou_mais_caracteres
PCP_ACCESS_TTL_MIN=15
PCP_REFRESH_TTL_DIAS=7
PCP_API_BIND=127.0.0.1:8080

# Admin inicial: criado no primeiro start SE não houver nenhum usuário (opcional).
PCP_ADMIN_EMAIL=admin@supercopo.local
PCP_ADMIN_SENHA=CHANGE_ME
