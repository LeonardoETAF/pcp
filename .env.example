# Modelo de variáveis de ambiente. Copie para `.env` e ajuste os valores.
# NUNCA versione o `.env` — ele guarda secrets (CLAUDE.md §7.4). Só este exemplo vai pro git.

# Conexão do Postgres dedicado (usada por SQLx e pelo app).
DATABASE_URL=postgres://pcp:CHANGE_ME@localhost:5433/pcp

# Banco SEPARADO para os testes de integração (#[ignore]). Os testes leem SÓ esta variável —
# nunca DATABASE_URL — para jamais sujarem o banco de desenvolvimento (CLAUDE.md §11/§6).
# Crie uma vez:  createdb -h localhost -p 5433 -U pcp pcp_test   (as migrations sobem sozinhas).
# Rode:          TEST_DATABASE_URL=postgres://pcp:CHANGE_ME@localhost:5433/pcp_test \
#                  cargo test --workspace -- --ignored
TEST_DATABASE_URL=postgres://pcp:CHANGE_ME@localhost:5433/pcp_test

# Usadas pelo docker-compose.yml ao subir o banco local.
POSTGRES_PASSWORD=CHANGE_ME
PCP_DB_PORT=5433

# Autenticação (CLAUDE.md §7). Segredo do JWT: use algo aleatório com 32+ caracteres.
PCP_JWT_SECRET=CHANGE_ME_use_um_segredo_aleatorio_com_32_ou_mais_caracteres
PCP_ACCESS_TTL_MIN=15
PCP_REFRESH_TTL_DIAS=7
PCP_API_BIND=127.0.0.1:8080

# Admin inicial: criado no primeiro start SE não houver nenhum usuário (opcional).
PCP_ADMIN_EMAIL=admin@supercopo.local
PCP_ADMIN_SENHA=CHANGE_ME

# ERP One (FONTE somente-leitura — CLAUDE.md §1/§8 e docs/integracao/acesso-direto-one.md).
# Usuário com GRANT SELECT apenas; o segredo fica SÓ no .env (gitignored), nunca no código.
# Dev: conexão local direta na LAN. Prod: conector on-premise (push TLS) — nunca expor o 9.5.
ONE_DATABASE_URL=postgres://pcp_ro:CHANGE_ME@192.168.88.251:5432/NOME_DO_BANCO?sslmode=prefer
# Sincronização contínua (serviço `sync-one`): intervalo do polling e profundidade do backfill
# inicial. 300s (5 min) é quase-tempo-real sem sobrecarregar o ERP legado (Postgres 9.5).
ONE_POLL_SEGUNDOS=300
ONE_BACKFILL_MESES=24

# Webhook de falha do pipeline (doc 05 §3): se um módulo falhar, o motor faz POST do JSON
# {evento, data_ref, modulos_com_erro} nesta URL (best-effort, com retry). Pode conter token →
# fica só no .env. Vazio/ausente desliga. Ex.: webhook de Slack/Discord/MS Teams.
PCP_WEBHOOK_FALHA_URL=
